def _gather_image_paths(paths):
    """Expand a mix of files and directories into image file paths."""
    IMAGE_EXTS = {".png", ".jpg", ".jpeg", ".heic", ".tiff", ".webp"}
    result = []
    for p in paths:
        p = Path(p)
        if p.is_dir():
            for f in sorted(p.iterdir()):
                if f.suffix.lower() in IMAGE_EXTS and not f.name.startswith("."):
                    result.append(f)
        elif p.is_file():
            result.append(p)
        else:
            print(f"{C.red('Error')}: {p} not found", file=sys.stderr)
    return result

def _info_for_image(p, device_dict):
    """Analyze a single image. Returns an info dict."""
    img = Image.open(p)
    w, h = img.size
    guard_image_size(w, h, p)
    info = {"file": str(p), "name": p.name, "width": w, "height": h}

    entry, model_name = detect_device(img, device_dict)
    if not entry:
        info["device"] = None
        info["error"] = f"Unknown device (width {w}px)"
        return info

    # Resolve variant
    variant_entry, resolved_name = resolve_variant(model_name, device_dict)
    if variant_entry:
        entry = variant_entry

    colors = FRAME_COLORS.get(resolved_name, [])
    variants = FRAME_VARIANTS.get(model_name, [])

    info.update({
        "device": resolved_name,
        "primary_match": model_name,
        "x": entry["x"], "y": entry["y"],
        "colors": colors,
        "color_count": len(colors),
        "has_mask": entry.get("mask") == "yes",
        "resize_width": entry.get("resizeWidth"),
        "variants": variants,
        "is_variant": resolved_name != model_name,
    })
    return info

def cmd_info(args):
    """Detect device for screenshots or scan a folder."""
    assets_dir = Path(args.assets) if hasattr(args, 'assets') and args.assets else get_assets_dir()
    device_dict = load_json(assets_dir)

    image_paths = _gather_image_paths(args.files)
    if not image_paths:
        print(f"{C.red('No images found.')}", file=sys.stderr)
        return

    results = []
    for p in image_paths:
        try:
            info = _info_for_image(p, device_dict)
            results.append(info)
        except Exception as e:
            results.append({"file": str(p), "name": p.name, "error": str(e)})

    if args.json:
        print(json.dumps(results if len(results) > 1 else results[0], indent=2))
        return

    # Pretty print
    matched = [r for r in results if r.get("device")]
    unmatched = [r for r in results if not r.get("device")]

    if len(image_paths) > 1:
        print(f"\n  {C.bold('Scanned')} {len(image_paths)} images: "
              f"{C.green(str(len(matched)) + ' matched')}, "
              f"{C.red(str(len(unmatched)) + ' unknown') if unmatched else C.dim('0 unknown')}")

    for r in results:
        print()
        print(f"  {C.bold(r['name'])}")
        if r.get("error"):
            print(f"  {C.red('✗')} {r['error']}")
            continue

        dims = f'{r["width"]} × {r["height"]}'
        print(f"  {C.dim(dims)}")

        device = r["device"]
        colors = r.get("colors", [])
        variants = r.get("variants", [])

        print(f"  {C.green('✓')} {C.bold(device)}")

        if r.get("is_variant"):
            print(f"    {C.dim('Primary match:')} {r['primary_match']} {C.dim('→ variant resolved')}")

        if colors:
            print(f"    {C.cyan(str(len(colors)))} colors: {C.dim(', '.join(colors[:5]))}"
                  + (f" {C.dim(f'(+{len(colors)-5} more)')}" if len(colors) > 5 else ""))
        else:
            print(f"    {C.dim('No color variants')}")

        if len(variants) > 1:
            alt = [v for v in variants if v != device]
            print(f"    {C.dim('Also available:')} {', '.join(alt)}")

        if r.get("resize_width"):
            print(f"    {C.dim('Scaled from')} {r['width']}px {C.dim('→')} {r['resize_width']}px")
        if r.get("has_mask"):
            print(f"    {C.dim('Mask applied')}")

    # Summary by device when scanning folders with many files
    if len(matched) > 3:
        from collections import Counter
        device_counts = Counter(r["device"] for r in matched)
        print(f"\n  {C.bold('Summary')}")
        for device, count in device_counts.most_common():
            colors = FRAME_COLORS.get(device, [])
            color_tag = f" ({len(colors)} colors)" if colors else ""
            print(f"    {count:3d}× {device}{C.dim(color_tag)}")
        if unmatched:
            print(f"    {C.red(f'{len(unmatched)}× unknown')}")
    print()

def copy_to_clipboard(path, announce=True):
    """Copy image to macOS clipboard."""
    try:
        safe_path = str(path).replace("\\", "\\\\").replace('"', '\\"')
        subprocess.run([
            "osascript", "-e",
            f'set the clipboard to (read (POSIX file "{safe_path}") as «class PNGf»)'
        ], check=True, capture_output=True)
        if announce:
            print(f"  {C.green('Copied to clipboard')}", file=sys.stderr)
    except (subprocess.CalledProcessError, FileNotFoundError):
        print(f"  {C.yellow('Warning')}: Could not copy to clipboard", file=sys.stderr)

# ── Argument Parsing ─────────────────────────────────────────────────────────

def build_parser():
    p = argparse.ArgumentParser(
        prog="frames",
        description="Frame screenshots with Apple device bezels",
        add_help=True,
    )
    p.add_argument("--version", action="version", version=f"frames v{VERSION}")
    p.add_argument("--no-color", action="store_true", help="Disable colored output")
    p.add_argument("--json", action="store_true", help="Output JSON (for AI agents)")
    p.add_argument("--assets", default=None, help="Assets directory path")
    p.add_argument("-v", "--verbose", action="store_true", help="Verbose output")

    sub = p.add_subparsers(dest="cmd")

    # Default frame command (also works without subcommand)
    frame_p = sub.add_parser("frame", help="Frame screenshots (default command)")
    frame_p.add_argument("files", nargs="*", help="Screenshot files to frame")
    frame_p.add_argument("--color", "-c", help="Frame color name, index, or 'random'")
    frame_p.add_argument("--merge", "-m", action="store_true", help="Merge framed images side by side")
    frame_p.add_argument("--batch", "-b", type=int, metavar="N", help="Merge in batches of N (e.g. -b 3 for groups of 3)")
    frame_p.add_argument("--spacing", "-s", type=int, default=60, help="Merge spacing in pixels (default: 60)")
    frame_p.add_argument("--no-scale", action="store_true", help="Disable proportional scaling when merging different devices")
    frame_p.add_argument("--output", "-o", help="Output directory")
    frame_p.add_argument("--copy", action="store_true", help="Copy result to clipboard")
    frame_p.add_argument("--device", "-d", help="Force specific device frame")
    frame_p.add_argument("-f", action="store_const", const="framed", dest="subfolder", help="Save to /framed/ subfolder")
    frame_p.add_argument("--subfolder", dest="subfolder", metavar="NAME", help="Save to custom subfolder (e.g. --subfolder mockups)")
    frame_p.add_argument("--json", action="store_true", dest="frame_json", help=argparse.SUPPRESS)

    # List command
    sub.add_parser("list", help="List supported devices")

    # List colors command (partial match)
    colors_p = sub.add_parser("list-colors", help="Show colors for a specific device")
    colors_p.add_argument("device_name", help="Device name (partial match)")

    # Colors command (browse all)
    sub.add_parser("colors", help="Browse all device colors")

    # Info command
    info_p = sub.add_parser("info", help="Detect device for screenshots or folders")
    info_p.add_argument("files", nargs="+", help="Screenshot files or directories to scan")

    # Setup command
    setup_p = sub.add_parser("setup", help="Download assets or configure path")
    setup_p.add_argument("path", nargs='?', default=None, help="Path to assets folder (omit to download)")
    setup_p.add_argument("--subfolder", action="store_true", default=None, help="Save framed images to /framed/ subfolder")
    setup_p.add_argument("--no-subfolder", action="store_false", dest="subfolder", help="Save framed images next to originals (default)")

    return p

def main():
    p = build_parser()

    # Pre-process argv: if the first non-flag arg isn't a known subcommand,
    # assume it's a file and inject "frame" as the subcommand
    known_cmds = {"frame", "list", "list-colors", "colors", "info", "setup", "-h", "--help", "--version"}
    argv = sys.argv[1:]
    if argv:
        global_flags = {"-h", "--help", "--version", "--no-color", "--json", "-v", "--verbose"}
        insert_at = 0
        idx = 0
        while idx < len(argv):
            arg = argv[idx]
            if arg in known_cmds:
                break
            if arg in global_flags:
                idx += 1
                insert_at = idx
                continue
            if arg == "--assets":
                idx += 2
                insert_at = min(idx, len(argv))
                continue
            if arg.startswith("--assets="):
                idx += 1
                insert_at = idx
                continue
            argv = argv[:insert_at] + ["frame"] + argv[insert_at:]
            break

    args = p.parse_args(argv)

    # Disable colors if requested
    if args.no_color or os.environ.get("NO_COLOR") or not sys.stdout.isatty():
        C.enabled = False

    # No command → show splash
    if args.cmd is None:
        if not args.json:
            show_splash()
        return

    # Propagate global flags
    if not hasattr(args, "verbose"):
        args.verbose = False
    if not hasattr(args, "json"):
        args.json = False
    if hasattr(args, "frame_json") and args.frame_json:
        args.json = True

    # Resolve assets directory (setup doesn't need it)
    if args.cmd != "setup":
        args.assets = str(get_assets_dir(args.assets))

    # Route commands
    cmds = {
        "frame": cmd_frame,
        "list": cmd_list,
        "list-colors": cmd_list_colors,
        "colors": cmd_colors,
        "info": cmd_info,
        "setup": cmd_setup,
    }
    handler = cmds.get(args.cmd)
    if handler:
        # Check assets exist and are v4+ (except for setup, colors, list-colors)
        if args.cmd not in ("setup", "colors", "list-colors"):
            ok, ver = check_assets_version(Path(args.assets))
            if not ok:
                if not sys.stdin.isatty() or args.json:
                    reason = "not found" if ver is None else f"outdated (version {ver})"
                    if args.json:
                        print(json.dumps({"error": f"Assets {reason}", "setup_required": True}))
                    else:
                        print(f"{C.red('Error')}: Assets {reason}. Run 'frames setup' interactively.", file=sys.stderr)
                    sys.exit(1)
                reason = "not found" if ver is None else f"outdated (version {ver})"
                if guided_setup(reason=reason):
                    args.assets = str(get_assets_dir())
                else:
                    sys.exit(1)
        handler(args)

if __name__ == "__main__":
    main()
