def cmd_frame(args):
    """Frame one or more screenshots."""
    assets_dir = Path(args.assets) if hasattr(args, 'assets') and args.assets else get_assets_dir()
    device_dict = load_json(assets_dir)

    if not args.files:
        print(f"{C.red('Error')}: No input files specified.", file=sys.stderr)
        sys.exit(1)

    batch_size = getattr(args, 'batch', None)
    if batch_size is not None and batch_size < 2:
        print(f"{C.red('Error')}: --batch must be at least 2.", file=sys.stderr)
        sys.exit(1)
    if args.spacing < 0:
        print(f"{C.red('Error')}: --spacing must be 0 or greater.", file=sys.stderr)
        sys.exit(1)

    # Expand directories into image files
    expanded = _gather_image_paths(args.files)
    if not expanded:
        print(f"{C.red('Error')}: No images found in the specified paths.", file=sys.stderr)
        sys.exit(1)

    framed = []
    infos = []

    for p in expanded:

        try:
            if not args.json:
                print(f"  {C.dim('Framing')} {p.name}...", end=" ", flush=True)

            result, info = frame_screenshot(
                p, assets_dir, device_dict,
                color_arg=args.color,
                force_device=args.device,
                verbose=args.verbose
            )
            framed.append((result, p, info))
            infos.append(info)

            if not args.json:
                color_str = f" ({C.rgb(235, 125, 40, info['color'])})" if info["color"] else ""
                print(f"{C.green(info['device'])}{color_str}")

        except (ValueError, FileNotFoundError, OSError, UnidentifiedImageError) as e:
            print(f"{C.red('Error')}: {e}", file=sys.stderr)
            continue

    if not framed:
        print(f"{C.red('No screenshots were framed.')}", file=sys.stderr)
        sys.exit(1)

    # Merge if requested (--merge or --batch implies merge)
    do_merge = args.merge or batch_size

    if do_merge and len(framed) > 1:
        # Split into batches
        if batch_size and batch_size > 0:
            batches = [framed[i:i+batch_size] for i in range(0, len(framed), batch_size)]
        else:
            batches = [framed]  # Single batch = merge all

        if args.output:
            out_dir = Path(args.output)
        elif get_subfolder_setting(args):
            out_dir = framed[0][1].parent / get_subfolder_setting(args)
        else:
            out_dir = framed[0][1].parent
        try:
            ensure_output_dir(out_dir)
        except OSError as e:
            print(f"{C.red('Error')}: {e}", file=sys.stderr)
            sys.exit(1)

        merged_outputs = []
        for batch_idx, batch in enumerate(batches):
            images = [f[0] for f in batch]

            # Collect physical heights for proportional scaling
            no_scale = getattr(args, 'no_scale', False)
            if not no_scale:
                phs = [f[2].get("physicalHeight", 0) for f in batch]
                physical_heights = phs if all(ph > 0 for ph in phs) else None
            else:
                physical_heights = None

            if len(images) == 1:
                merged = images[0]
            else:
                merged = merge_images(images, spacing=args.spacing, physical_heights=physical_heights)

            if len(batches) == 1:
                out_name = "merged_framed.png"
            else:
                out_name = f"merged_{batch_idx + 1}_framed.png"

            out_path = out_dir / out_name
            try:
                save_png(merged, out_path)
            except OSError as e:
                print(f"{C.red('Error')}: {e}", file=sys.stderr)
                sys.exit(1)
            merged_outputs.append(str(out_path))

            if not args.json:
                batch_count = len(batch)
                scaled_msg = ""
                if physical_heights and len(set(physical_heights)) > 1:
                    max_ph = max(physical_heights)
                    scaled_msg = f" {C.dim('(proportional)')}"
                print(f"\n  {C.green('Merged')} {batch_count} frames → {C.bold(str(out_path))}{scaled_msg}")

        if args.copy and len(merged_outputs) == 1:
            copy_to_clipboard(Path(merged_outputs[0]), announce=not args.json)

        if args.json:
            # Add scale factors when proportional scaling was applied
            all_phs = [info.get("physicalHeight", 0) for info in infos]
            if not no_scale and all(ph > 0 for ph in all_phs) and len(set(all_phs)) > 1:
                # Mirror the actual merge algorithm: normalize to lowest px/mm
                frame_heights = [int(info["frame_size"].split("x")[1]) for info in infos]
                px_per_mm = [fh / ph for fh, ph in zip(frame_heights, all_phs)]
                ref_ppm = min(px_per_mm)
                for info, fh, ph in zip(infos, frame_heights, all_phs):
                    target_h = round(ph * ref_ppm)
                    info["scale_factor"] = round(target_h / fh, 4)

            if len(batches) == 1:
                result_json = {"merged": merged_outputs[0], "count": len(framed), "frames": infos}
            else:
                result_json = {
                    "batches": [{"merged": p, "count": len(b)} for p, b in zip(merged_outputs, batches)],
                    "batch_size": batch_size,
                    "total": len(framed),
                    "frames": infos,
                }
            print(json.dumps(result_json, indent=2))

    else:
        # Save individual framed images
        outputs = []
        for result_img, src_path, info in framed:
            if args.output:
                out_dir = Path(args.output)
            elif get_subfolder_setting(args):
                out_dir = src_path.parent / get_subfolder_setting(args)
            else:
                out_dir = src_path.parent
            try:
                ensure_output_dir(out_dir)
                out_path = out_dir / f"{src_path.stem}_framed.png"
                save_png(result_img, out_path)
            except OSError as e:
                print(f"{C.red('Error')}: {e}", file=sys.stderr)
                sys.exit(1)

            info["output"] = str(out_path)
            outputs.append(str(out_path))

            if not args.json:
                print(f"  {C.dim('→')} {C.bold(str(out_path))}")

        if args.copy and len(outputs) == 1:
            copy_to_clipboard(Path(outputs[0]), announce=not args.json)

        if args.json:
            if len(infos) == 1:
                print(json.dumps(infos[0], indent=2))
            else:
                print(json.dumps({"frames": infos}, indent=2))

    if not args.json:
        print()

def cmd_list(args):
    """List all supported devices."""
    assets_dir = Path(args.assets) if hasattr(args, 'assets') and args.assets else get_assets_dir()
    device_dict = load_json(assets_dir)

    print(f"\n  {C.bold('Supported Devices')}\n")

    # Group by category
    categories = {
        "iPhone 17": [], "iPhone Air": [], "iPhone 16": [],
        "iPhone 12-13": [], "iPhone 8": [],
        "iPad": [], "MacBook": [], "iMac": [], "Studio Display": [], "Watch": [],
    }

    for key in sorted(device_dict.keys(), key=lambda k: int(k) if k != "variants" else 0):
        if key == "variants":
            continue
        entry = device_dict[key]

        # Expand overlap entries (detect_device only checks overlap sub-entries)
        if "overlap" in entry:
            sub_entries = list(entry["overlap"].values())
        else:
            sub_entries = [entry]

        for sub in sub_entries:
            name = sub["name"]
            has_colors = sub.get("colors") == "yes"
            resize = sub.get("resizeWidth")

            for cat in categories:
                if name.startswith(cat) or (cat == "MacBook" and "MacBook" in name) or (cat == "Watch" and "Watch" in name) or (cat == "Studio Display" and "Studio Display" in name):
                    flags = []
                    if has_colors:
                        colors = FRAME_COLORS.get(name, [])
                        if colors:
                            flags.append(f"{len(colors)} colors")
                    if resize:
                        flags.append("scaled")
                    flag_str = C.dim(f" ({', '.join(flags)})") if flags else ""
                    categories[cat].append(f"    {C.cyan(f'{key:>5}px')} → {name}{flag_str}")
                    break

    for cat, entries in categories.items():
        if entries:
            print(f"  {C.bold(cat)}")
            for e in entries:
                print(e)
            print()

    # Show variant defaults
    print(f"  {C.bold('Default Variants')} {C.dim('(newest device used automatically)')}")
    for primary, variants in FRAME_VARIANTS.items():
        default = variants[0]
        if default != primary:
            print(f"    {C.dim(primary)} → {C.green(default)}")
    print()

