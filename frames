    # Group by category
    categories = {
        "iPhone 17": [], "iPhone Air": [], "iPhone 16": [],
        "iPhone 12-13": [], "iPhone 8": [],
        "iPad": [], "MacBook": [], "iMac": [], "Watch": [],
    }

    for key in sorted(device_dict.keys(), key=lambda k: int(k) if k != "variants" else 0):
        if key == "variants":
            continue
        entry = device_dict[key]
        name = entry["name"]
        has_colors = entry.get("colors") == "yes"
        has_mask = entry.get("mask") == "yes"
        resize = entry.get("resizeWidth")

        for cat in categories:
            if name.startswith(cat) or (cat == "MacBook" and "MacBook" in name) or (cat == "Watch" and "Watch" in name):
                flags = []
                if has_colors:
                    colors = FRAME_COLORS.get(name, [])
                    flags.append(f"{len(colors)} colors")
                if resize:
                    flags.append("scaled")
                flag_str = C.dim(f" ({', '.join(flags)})") if flags else ""
                categories[cat].append(f"    {C.cyan(f'{key:>5}px')} → {name}{flag_str}")
                break

    for cat, entries in categories.items():
        if entries:
            print(f"  {C.bold(cat)}")
            for e in entries:
                print(e)
            print()

    # Show variant defaults
    print(f"  {C.bold('Default Variants')} {C.dim('(newest device used automatically)')}")
    for primary, variants in FRAME_VARIANTS.items():
        default = variants[0]
        if default != primary:
            print(f"    {C.dim(primary)} → {C.green(default)}")
    print()

def cmd_list_colors(args):
    """List colors for a specific device (partial match)."""
    device = args.device_name
    matches = [(k, v) for k, v in FRAME_COLORS.items() if device.lower() in k.lower()]

    if not matches:
        print(f"{C.red('Error')}: No device matching '{device}'", file=sys.stderr)
        sys.exit(1)

    print()
    for name, colors in matches:
        print(f"  {C.bold(name)}")
        for i, color in enumerate(colors):
            default = C.dim(" (default)") if i == 0 else ""
            print(f"    {C.cyan(str(i+1))}. {color}{default}")
        print()

def _build_device_list():
    """Build deduplicated device→colors list (no portrait/landscape dupes)."""
    devices = []
    for name, colors in FRAME_COLORS.items():
        base = name.replace(" Portrait", "").replace(" Landscape", "")
        if not any(d[0] == base for d in devices):
            devices.append((base, list(colors)))
    return devices

def _colors_curses(stdscr):
    """Curses-based interactive color picker."""
    curses.curs_set(0)
    curses.use_default_colors()
    curses.start_color()
    curses.init_pair(1, 209, -1)   # Orange
    curses.init_pair(2, 250, -1)   # Dim
    curses.init_pair(3, 15, -1)    # Bold white
    curses.init_pair(4, 46, -1)    # Green

    devices = _build_device_list()
    cfg = load_config()
    user_defaults = cfg.get("default_colors", {})
    selected = {}
    for base, colors in devices:
        if base in user_defaults and user_defaults[base] in colors:
            selected[base] = colors.index(user_defaults[base])
        else:
            selected[base] = 0

    # Flat list of navigable items
    items = []
    for base, colors in devices:
        for ci in range(len(colors)):
            items.append((base, ci))

    cursor = 0
    changed = False

    while True:
        stdscr.clear()
        h, w = stdscr.getmaxyx()

        # Header
        try:
            stdscr.addstr(0, 2, "Default Colors", curses.A_BOLD)
            stdscr.addstr(0, 18, "  ↑↓ navigate  space select  enter save  q cancel", curses.color_pair(2))
        except curses.error:
            pass

        row = 2
        idx = 0
        # Calculate scroll offset so cursor is always visible
        # Each device takes len(colors) + 2 rows (header + colors + blank)
        # Simple approach: center the view around cursor
        total_rows = sum(len(c) + 2 for _, c in devices)
        scroll_offset = 0
        if total_rows > h - 4:
            # Find which row the cursor is on
            cursor_row = 2
            ci = 0
            for base, colors in devices:
                cursor_row += 1  # device header
                for c_idx in range(len(colors)):
                    if ci == cursor:
                        break
                    cursor_row += 1
                    ci += 1
                else:
                    cursor_row += 1  # blank line
                    continue
                break
            scroll_offset = max(0, cursor_row - h // 2)

        row = 2 - scroll_offset
        idx = 0
        for base, colors in devices:
            if 0 <= row < h:
                try:
                    stdscr.addstr(row, 2, base, curses.A_BOLD)
                except curses.error:
                    pass
            row += 1

            for ci, color in enumerate(colors):
                if 0 <= row < h - 1:
                    is_cursor = (idx == cursor)
                    is_selected = (selected[base] == ci)

                    try:
                        if is_cursor:
                            stdscr.addstr(row, 2, "▸ ", curses.A_BOLD)
                        else:
                            stdscr.addstr(row, 2, "  ")

                        if is_selected:
                            stdscr.addstr(row, 4, "● ", curses.color_pair(1))
                        else:
                            stdscr.addstr(row, 4, "○ ", curses.color_pair(2))

                        attr = curses.A_BOLD if is_cursor else 0
                        stdscr.addstr(row, 6, color, attr)
                    except curses.error:
                        pass
                row += 1
                idx += 1
            row += 1  # blank between devices

        stdscr.refresh()

        key = stdscr.getch()
        if key == curses.KEY_DOWN:
            cursor = min(cursor + 1, len(items) - 1)
        elif key == curses.KEY_UP:
            cursor = max(cursor - 1, 0)
        elif key == ord(' '):
            base, ci = items[cursor]
            selected[base] = ci
            changed = True
        elif key in (ord('\n'), ord('\r')):
            if changed:
                defaults = {}
                for base, colors in devices:
                    defaults[base] = colors[selected[base]]
                cfg["default_colors"] = defaults
                save_config(cfg)
            return changed, selected, devices
        elif key in (ord('q'), 27):  # q or Esc
            return False, selected, devices

def cmd_colors(args):
    """Interactive color picker — arrow keys to navigate, space to select, enter to save."""
    O = lambda t: C.rgb(232, 114, 42, t)

    if not sys.stdin.isatty():
        # Non-interactive fallback
        devices = _build_device_list()
        cfg = load_config()
        user_defaults = cfg.get("default_colors", {})
        print(f"\n  {C.bold('All Device Colors')}\n")
        for base, colors in devices:
            print(f"  {C.bold(base)}")
            for i, color in enumerate(colors):
                is_default = (base in user_defaults and user_defaults[base] == color) or (base not in user_defaults and i == 0)
                marker = O("●") if is_default else C.dim("○")
                print(f"    {marker} {color}")
            print()
        return

    changed, selected, devices = curses.wrapper(_colors_curses)

    if changed:
        print(f"\n  {C.green('Defaults saved!')}\n")
        for base, colors in devices:
            color = colors[selected[base]]
            print(f"    {O('●')} {C.bold(base)}: {color}")
        print()
    else:
        print(f"\n  {C.dim('No changes saved.')}\n")

def cmd_setup(args):
    """Configure the assets directory path."""
    assets_path = Path(args.path).resolve()

    # Validate the path
    if not assets_path.exists():
        print(f"{C.red('Error')}: Path does not exist: {assets_path}", file=sys.stderr)
        sys.exit(1)

    json_file = assets_path / "NewFrames.json"
    if not json_file.exists():
        print(f"{C.red('Error')}: NewFrames.json not found in {assets_path}", file=sys.stderr)
        print(f"  {C.dim('The path should point to the folder containing NewFrames.json and frame PNGs.')}", file=sys.stderr)
        sys.exit(1)

    # Count assets
    pngs = list(assets_path.glob("*.png"))
    with open(json_file) as f:
        device_dict = json.load(f)
    device_count = len([k for k in device_dict if k != "variants"])

    # Save config
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    config = {}
    if CONFIG_FILE.exists():
        try:
            with open(CONFIG_FILE) as f:
                config = json.load(f)
        except json.JSONDecodeError:
            pass
    config["assets_path"] = str(assets_path)
    if hasattr(args, 'subfolder') and args.subfolder is not None:
        config["use_subfolder"] = args.subfolder
    with open(CONFIG_FILE, "w") as f:
        json.dump(config, f, indent=2)

    subfolder_status = config.get("use_subfolder", False)

    print()
    print(f"  {C.green('Setup complete!')}")
    print(f"  {C.bold('Assets path:')} {assets_path}")
    print(f"  {C.bold('Frame PNGs:')}  {len(pngs)}")
    print(f"  {C.bold('Devices:')}     {device_count}")
    print(f"  {C.bold('Subfolder:')}   {'on' if subfolder_status else 'off'} {C.dim('(save to /framed/ subfolder)')}")
    print(f"  {C.bold('Config:')}      {CONFIG_FILE}")
    print()
    print(f"  {C.dim('You can now run')} {C.cyan('frames screenshot.png')} {C.dim('from anywhere.')}")
    print()

def _gather_image_paths(paths):
    """Expand a mix of files and directories into image file paths."""
    IMAGE_EXTS = {".png", ".jpg", ".jpeg", ".heic", ".tiff", ".webp"}
    result = []
    for p in paths:
        p = Path(p)
        if p.is_dir():
            for f in sorted(p.iterdir()):
                if f.suffix.lower() in IMAGE_EXTS and not f.name.startswith("."):
                    result.append(f)
        elif p.is_file():
            result.append(p)
        else:
            print(f"{C.red('Error')}: {p} not found", file=sys.stderr)
    return result

def _info_for_image(p, device_dict):
    """Analyze a single image. Returns an info dict."""
    img = Image.open(p)
    w, h = img.size
    info = {"file": str(p), "name": p.name, "width": w, "height": h}

    entry, model_name = detect_device(img, device_dict)
    if not entry:
        info["device"] = None
        info["error"] = f"Unknown device (width {w}px)"
        return info

    # Resolve variant
    variant_entry, resolved_name = resolve_variant(model_name, device_dict)
    if variant_entry:
        entry = variant_entry

    colors = FRAME_COLORS.get(resolved_name, [])
    variants = FRAME_VARIANTS.get(model_name, [])

    info.update({
        "device": resolved_name,
        "primary_match": model_name,
        "x": entry["x"], "y": entry["y"],
        "colors": colors,
        "color_count": len(colors),
        "has_mask": entry.get("mask") == "yes",
        "resize_width": entry.get("resizeWidth"),
        "variants": variants,
        "is_variant": resolved_name != model_name,
    })
    return info

def cmd_info(args):
    """Detect device for screenshots or scan a folder."""
    assets_dir = Path(args.assets) if hasattr(args, 'assets') and args.assets else get_assets_dir()
    device_dict = load_json(assets_dir)

    image_paths = _gather_image_paths(args.files)
    if not image_paths:
        print(f"{C.red('No images found.')}", file=sys.stderr)
        return

    results = []
    for p in image_paths:
        try:
            info = _info_for_image(p, device_dict)
            results.append(info)
        except Exception as e:
            results.append({"file": str(p), "name": p.name, "error": str(e)})

    if args.json:
        print(json.dumps(results if len(results) > 1 else results[0], indent=2))
        return

    # Pretty print
    matched = [r for r in results if r.get("device")]
    unmatched = [r for r in results if not r.get("device")]

    if len(image_paths) > 1:
        print(f"\n  {C.bold('Scanned')} {len(image_paths)} images: "
              f"{C.green(str(len(matched)) + ' matched')}, "
              f"{C.red(str(len(unmatched)) + ' unknown') if unmatched else C.dim('0 unknown')}")

    for r in results:
        print()
        print(f"  {C.bold(r['name'])}")
        dims = f'{r["width"]} × {r["height"]}'
        print(f"  {C.dim(dims)}")

        if r.get("error"):
            print(f"  {C.red('✗')} {r['error']}")
            continue

        device = r["device"]
        colors = r.get("colors", [])
        variants = r.get("variants", [])

        print(f"  {C.green('✓')} {C.bold(device)}")

        if r.get("is_variant"):
            print(f"    {C.dim('Primary match:')} {r['primary_match']} {C.dim('→ variant resolved')}")

        if colors:
            print(f"    {C.cyan(str(len(colors)))} colors: {C.dim(', '.join(colors[:5]))}"
                  + (f" {C.dim(f'(+{len(colors)-5} more)')}" if len(colors) > 5 else ""))
        else:
            print(f"    {C.dim('No color variants')}")

        if len(variants) > 1:
            alt = [v for v in variants if v != device]
            print(f"    {C.dim('Also available:')} {', '.join(alt)}")

        if r.get("resize_width"):
            print(f"    {C.dim('Scaled from')} {r['width']}px {C.dim('→')} {r['resize_width']}px")
        if r.get("has_mask"):
            print(f"    {C.dim('Mask applied')}")

    # Summary by device when scanning folders with many files
    if len(matched) > 3:
        from collections import Counter
        device_counts = Counter(r["device"] for r in matched)
        print(f"\n  {C.bold('Summary')}")
        for device, count in device_counts.most_common():
            colors = FRAME_COLORS.get(device, [])
            color_tag = f" ({len(colors)} colors)" if colors else ""
            print(f"    {count:3d}× {device}{C.dim(color_tag)}")
        if unmatched:
            print(f"    {C.red(f'{len(unmatched)}× unknown')}")
    print()

def copy_to_clipboard(path):
    """Copy image to macOS clipboard."""
    try:
        subprocess.run([
            "osascript", "-e",
            f'set the clipboard to (read (POSIX file "{path}") as «class PNGf»)'
        ], check=True, capture_output=True)
        print(f"  {C.green('Copied to clipboard')}")
    except subprocess.CalledProcessError:
        print(f"  {C.yellow('Warning')}: Could not copy to clipboard", file=sys.stderr)

# ── Argument Parsing ─────────────────────────────────────────────────────────

def build_parser():
    p = argparse.ArgumentParser(
        prog="frames",
        description="Frame screenshots with Apple device bezels",
        add_help=True,
    )
    p.add_argument("--version", action="version", version=f"frames v{VERSION}")
    p.add_argument("--no-color", action="store_true", help="Disable colored output")
    p.add_argument("--json", action="store_true", help="Output JSON (for AI agents)")
    p.add_argument("--assets", default=None, help="Assets directory path")
    p.add_argument("-v", "--verbose", action="store_true", help="Verbose output")

    sub = p.add_subparsers(dest="cmd")

    # Default frame command (also works without subcommand)
    frame_p = sub.add_parser("frame", help="Frame screenshots (default command)")
    frame_p.add_argument("files", nargs="*", help="Screenshot files to frame")
    frame_p.add_argument("--color", "-c", help="Frame color name, index, or 'random'")
    frame_p.add_argument("--merge", "-m", action="store_true", help="Merge framed images side by side")
    frame_p.add_argument("--batch", "-b", type=int, metavar="N", help="Merge in batches of N (e.g. -b 3 for groups of 3)")
    frame_p.add_argument("--spacing", "-s", type=int, default=60, help="Merge spacing in pixels (default: 60)")
    frame_p.add_argument("--output", "-o", help="Output directory")
    frame_p.add_argument("--copy", action="store_true", help="Copy result to clipboard")
    frame_p.add_argument("--device", "-d", help="Force specific device frame")
    frame_p.add_argument("-f", action="store_const", const="framed", dest="subfolder", help="Save to /framed/ subfolder")
    frame_p.add_argument("--subfolder", dest="subfolder", metavar="NAME", help="Save to custom subfolder (e.g. --subfolder mockups)")
    frame_p.add_argument("--json", action="store_true", dest="frame_json", help=argparse.SUPPRESS)

    # List command
    sub.add_parser("list", help="List supported devices")

    # List colors command (partial match)
    colors_p = sub.add_parser("list-colors", help="Show colors for a specific device")
    colors_p.add_argument("device_name", help="Device name (partial match)")

    # Colors command (browse all)
    sub.add_parser("colors", help="Browse all device colors")

    # Info command
    info_p = sub.add_parser("info", help="Detect device for screenshots or folders")
    info_p.add_argument("files", nargs="+", help="Screenshot files or directories to scan")

    # Setup command
    setup_p = sub.add_parser("setup", help="Configure assets directory path")
    setup_p.add_argument("path", help="Path to Frames assets folder")
    setup_p.add_argument("--subfolder", action="store_true", default=None, help="Save framed images to /framed/ subfolder")
    setup_p.add_argument("--no-subfolder", action="store_false", dest="subfolder", help="Save framed images next to originals (default)")

    return p

def main():
    p = build_parser()

    # Pre-process argv: if the first non-flag arg isn't a known subcommand,
    # assume it's a file and inject "frame" as the subcommand
    known_cmds = {"frame", "list", "list-colors", "colors", "info", "setup", "-h", "--help", "--version"}
    argv = sys.argv[1:]
    if argv:
        first_non_flag = next((a for a in argv if not a.startswith("-")), None)
        if first_non_flag and first_non_flag not in known_cmds:
            argv = ["frame"] + argv

    args = p.parse_args(argv)

    # Disable colors if requested
    if args.no_color or os.environ.get("NO_COLOR") or not sys.stdout.isatty():
        C.enabled = False

    # No command → show splash
    if args.cmd is None:
        if not args.json:
            show_splash()
        return

    # Propagate global flags
    if not hasattr(args, "verbose"):
        args.verbose = False
    if not hasattr(args, "json"):
        args.json = False
    if hasattr(args, "frame_json") and args.frame_json:
        args.json = True

    # Resolve assets directory (setup doesn't need it)
    if args.cmd != "setup":
        args.assets = str(get_assets_dir(args.assets))

    # Route commands
    cmds = {
        "frame": cmd_frame,
        "list": cmd_list,
        "list-colors": cmd_list_colors,
        "colors": cmd_colors,
        "info": cmd_info,
        "setup": cmd_setup,
    }
    handler = cmds.get(args.cmd)
    if handler:
        # Check assets exist (except for setup and colors)
        if args.cmd not in ("setup", "colors", "list-colors") and not Path(args.assets).exists():
            print(f"\n  {C.red('Assets not found!')} Run setup first:\n")
            print(f"    {C.cyan('frames')} setup /path/to/NewFrames\n")
            print(f"  {C.dim('The NewFrames folder contains frame PNGs and NewFrames.json.')}")
            print(f"  {C.dim('If using the Apple Frames shortcut, it is typically at:')}")
            print(f"  {C.dim('~/Library/Mobile Documents/iCloud~is~workflow~my~workflows/Documents/NewFrames/')}\n")
            sys.exit(1)
        handler(args)
    else:
        show_splash()

if __name__ == "__main__":
    main()
