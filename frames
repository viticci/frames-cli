def _build_device_list():
    """Build deduplicated device→colors list (no portrait/landscape dupes)."""
    devices = []
    for name, colors in FRAME_COLORS.items():
        base = name.replace(" Portrait", "").replace(" Landscape", "")
        if not any(d[0] == base for d in devices):
            devices.append((base, list(colors)))
    return devices

def _print_colors_fallback():
    """Print device colors without curses."""
    O = lambda t: C.rgb(232, 114, 42, t)
    devices = _build_device_list()
    cfg = load_config()
    user_defaults = cfg.get("default_colors", {})
    print(f"\n  {C.bold('All Device Colors')}\n")
    for base, colors in devices:
        print(f"  {C.bold(base)}")
        for i, color in enumerate(colors):
            is_default = (base in user_defaults and user_defaults[base] == color) or (base not in user_defaults and i == 0)
            marker = O("●") if is_default else C.dim("○")
            print(f"    {marker} {color}")
        print()

def _colors_curses(stdscr):
    """Curses-based interactive color picker."""
    import curses

    curses.curs_set(0)
    curses.use_default_colors()
    curses.start_color()
    curses.init_pair(1, 209, -1)   # Orange
    curses.init_pair(2, 250, -1)   # Dim

    devices = _build_device_list()
    cfg = load_config()
    user_defaults = cfg.get("default_colors", {})
    selected = {}
    for base, colors in devices:
        if base in user_defaults and user_defaults[base] in colors:
            selected[base] = colors.index(user_defaults[base])
        else:
            selected[base] = 0

    # Flat list of navigable items
    items = []
    for base, colors in devices:
        for ci in range(len(colors)):
            items.append((base, ci))

    cursor = 0
    changed = False

    while True:
        stdscr.clear()
        h, w = stdscr.getmaxyx()

        # Header
        try:
            stdscr.addstr(0, 2, "Default Colors", curses.A_BOLD)
            stdscr.addstr(0, 18, "  ↑↓ navigate  space select  enter save  q cancel", curses.color_pair(2))
        except curses.error:
            pass

        row = 2
        idx = 0
        # Calculate scroll offset so cursor is always visible
        # Each device takes len(colors) + 2 rows (header + colors + blank)
        # Simple approach: center the view around cursor
        total_rows = sum(len(c) + 2 for _, c in devices)
        scroll_offset = 0
        if total_rows > h - 4:
            # Find which row the cursor is on
            cursor_row = 2
            ci = 0
            for base, colors in devices:
                cursor_row += 1  # device header
                for c_idx in range(len(colors)):
                    if ci == cursor:
                        break
                    cursor_row += 1
                    ci += 1
                else:
                    cursor_row += 1  # blank line
                    continue
                break
            scroll_offset = max(0, cursor_row - h // 2)

        row = 2 - scroll_offset
        idx = 0
        for base, colors in devices:
            if 0 <= row < h:
                try:
                    stdscr.addstr(row, 2, base, curses.A_BOLD)
                except curses.error:
                    pass
            row += 1

            for ci, color in enumerate(colors):
                if 0 <= row < h - 1:
                    is_cursor = (idx == cursor)
                    is_selected = (selected[base] == ci)

                    try:
                        if is_cursor:
                            stdscr.addstr(row, 2, "▸ ", curses.A_BOLD)
                        else:
                            stdscr.addstr(row, 2, "  ")

                        if is_selected:
                            stdscr.addstr(row, 4, "● ", curses.color_pair(1))
                        else:
                            stdscr.addstr(row, 4, "○ ", curses.color_pair(2))

                        attr = curses.A_BOLD if is_cursor else 0
                        stdscr.addstr(row, 6, color, attr)
                    except curses.error:
                        pass
                row += 1
                idx += 1
            row += 1  # blank between devices

        stdscr.refresh()

        key = stdscr.getch()
        if key == curses.KEY_DOWN:
            cursor = min(cursor + 1, len(items) - 1)
        elif key == curses.KEY_UP:
            cursor = max(cursor - 1, 0)
        elif key == ord(' '):
            base, ci = items[cursor]
            selected[base] = ci
            changed = True
        elif key in (ord('\n'), ord('\r')):
            if changed:
                defaults = {}
                for base, colors in devices:
                    defaults[base] = colors[selected[base]]
                cfg["default_colors"] = defaults
                save_config(cfg)
            return changed, selected, devices
        elif key in (ord('q'), 27):  # q or Esc
            return False, selected, devices

def cmd_colors(args):
    """Interactive color picker — arrow keys to navigate, space to select, enter to save."""
    O = lambda t: C.rgb(232, 114, 42, t)

    if not sys.stdin.isatty():
